config.admPanel = 1

plugin {
    tx_t3sitepackageonemorephoto {
        mvc {
            callDefaultActionIfActionCantBeResolved = 1
        }
        view {
            templateRootPaths {
                0 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Site/Templates/
                1 = {$T3SitepackageOnemorephoto.view.templateRootPath}
            }
            partialRootPaths {
                0 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Site/Partials/
                1 = {$T3SitepackageOnemorephoto.view.partialRootPath}
            }
            layoutRootPaths {
                0 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Site/Layouts/
                1 = {$T3SitepackageOnemorephoto.view.layoutRootPath}
            }
        }
        settings {
            orderByAllowed = title,tstamp,date_release,crdate,username
        }
    }

    tx_form {
        mvc {
            callDefaultActionIfActionCantBeResolved = 1
        }
        settings {
            yamlConfigurations {
                110 = EXT:t3_sitepackage_onemorephoto/Configuration/Form/setup.yaml
            }
        }
        view {
            layoutRootPaths {
                0 = EXT:form/Resources/Private/Frontend/Layouts/
                10 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Extensions/Cms/Form/Layouts/
            }
            partialRootPaths {
                0 = EXT:form/Resources/Private/Frontend/Partials/
                10 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Extensions/Cms/Form/Partials/
            }
            templateRootPaths {
                0 = EXT:form/Resources/Private/Frontend/Templates/
                10 = EXT:t3_sitepackage_onemorephoto/Resources/Private/Extensions/Cms/Form/Templates/
            }
        }
    }
}
